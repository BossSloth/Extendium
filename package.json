{
  "scripts": {
    "dev": "millennium-ttc --build dev --watch",
    "sass": "sass ./public/extendium.scss:./public/extendium.css --style compressed --embed-sources --embed-source-map",
    "watch": "nodemon --watch public/extendium.scss --exec \"npm run sass && npm run dev\"",
    "build": "npm run sass && millennium-ttc --build prod",
    "lint": "eslint"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/bun": "^1.3.9",
    "@types/chrome": "^0.1.37",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webpack": "^5.28.5",
    "devtools-protocol": "^0.0.1591319",
    "eslint": "^9.39.3",
    "eslint-plugin-perfectionist": "^4.15.1",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.3.0",
    "knip": "^5.86.0",
    "nodemon": "^3.1.14",
    "semantic-release": "^24.2.9",
    "steam-types": "^2.1.0",
    "typescript-eslint": "^8.56.1"
  },
  "type": "module",
  "name": "extendium",
  "version": "2.0.0",
  "description": "A plugin for Millennium that adds chrome extensions support to the client",
  "main": "./frontend/index.jsx",
  "author": "BossSloth",
  "license": "MIT",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@steambrew/api": "^5.8.4",
    "@steambrew/client": "^5.8.4",
    "@steambrew/ttc": "^3.2.6",
    "@steambrew/webkit": "5.8.4",
    "react-icons": "^5.5.0",
    "sass-embedded": "^1.97.3",
    "zustand": "^5.0.11"
  },
  "patchedDependencies": {
    "@steambrew/client@5.8.4": "patches/@steambrew%2Fclient@5.8.4.patch"
  }
}
